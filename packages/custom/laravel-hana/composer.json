{
    "name": "custom/laravel-hana",
    "description": "SAP HANA database driver for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Custom",
            "email": "dev@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Custom\\LaravelHana\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Custom\\LaravelHana\\HanaServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
